generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  OPERATOR
}

enum ItemStatus {
  AVAILABLE
  LOANED
  OUT_OF_SERVICE
}

enum ReturnMethod {
  SCAN
  MANUAL
}

model Sede {
  id        String     @id @default(cuid())
  name      String
  active    Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  users      User[]
  categories Category[]
  items      Item[]
  loans      Loan[]
}

model User {
  id           String   @id @default(cuid())
  name         String
  username     String   @unique
  passwordHash String
  role         Role
  sedeId       String?
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  sede Sede? @relation(fields: [sedeId], references: [id])

  @@index([sedeId])
}

model Category {
  id        String   @id @default(cuid())
  name      String
  sedeId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sede  Sede   @relation(fields: [sedeId], references: [id])
  items Item[]

  @@index([sedeId])
}

model Item {
  id           String     @id @default(cuid())
  internalCode String     @unique
  name         String
  description  String?
  categoryId   String
  sedeId       String
  status       ItemStatus @default(AVAILABLE)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  category Category @relation(fields: [categoryId], references: [id])
  sede     Sede     @relation(fields: [sedeId], references: [id])
  loans    Loan[]

  @@index([sedeId])
  @@index([categoryId])
  @@index([sedeId, status])
}

model Student {
  id        String   @id @default(cuid())
  run       String   @unique
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  loans Loan[]
}

model Loan {
  id             String        @id @default(cuid())
  itemId         String
  studentId      String
  sedeId         String
  loanDate       DateTime      @default(now())
  returnDate     DateTime?
  returnedOnTime Boolean?
  returnMethod   ReturnMethod?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  item    Item    @relation(fields: [itemId], references: [id])
  student Student @relation(fields: [studentId], references: [id])
  sede    Sede    @relation(fields: [sedeId], references: [id])

  @@index([sedeId, returnDate])
  @@index([studentId])
  @@index([loanDate])
  @@index([itemId, returnDate])
}
